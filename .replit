run = "hugo && miniserve public --index index.html"
# run = "hugo"
entrypoint = "content/posts/hello.md"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "hugo server --bind 0.0.0.0 --port 5000 --baseURL / --appendPort=false"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

